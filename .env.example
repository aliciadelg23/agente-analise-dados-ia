# Copie este arquivo para .env e preencha os valores locais.
# Nunca commite o .env real.

# Ambiente de execução: development | staging | production
APP_ENV=development

# Bind do servidor HTTP
APP_HOST=0.0.0.0
APP_PORT=8000

# Nível do logger raiz: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Diretório base (relativo à raiz) onde arquivos enviados serão salvos
STORAGE_DIR=storage

# Tamanho máximo aceito para upload de datasets, em megabytes
MAX_UPLOAD_SIZE_MB=50

# Prefixo de URL sob o qual os gráficos gerados serão servidos
CHARTS_STATIC_URL_PREFIX=/static/charts

# Subdiretório dentro de STORAGE_DIR onde modelos treinados são salvos
MODELS_DIR_NAME=models

# Chaves de LLM (placeholders — ainda não utilizados nesta etapa)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
