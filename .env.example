# Copie este arquivo para .env e preencha os valores locais.
# Nunca commite o .env real.

# Ambiente de execução: development | staging | production
APP_ENV=development

# Bind do servidor HTTP
APP_HOST=0.0.0.0
APP_PORT=8000

# Nível do logger raiz: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Chaves de LLM (placeholders — ainda não utilizados nesta etapa)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
